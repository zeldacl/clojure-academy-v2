{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(grep -E \"\\\\.clj$\")",
      "Bash(grep:*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)"
    ]
  },
  "enabledMcpjsonServers": [
    "clojure-lsp",
    "java-lsp"
  ],
  "enabledPlugins": {
    "context7@claude-plugins-official": false
  }
}
