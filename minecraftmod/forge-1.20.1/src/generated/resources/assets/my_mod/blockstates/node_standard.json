{
  "multipart": [
    {
      "apply": {
        "model": "my_mod:block/node_standard_base"
      }
    },
    {
      "apply": {
        "model": "my_mod:block/node_standard_energy_0"
      },
      "when": {
        "energy": "0"
      }
    },
    {
      "apply": {
        "model": "my_mod:block/node_standard_energy_1"
      },
      "when": {
        "energy": "1"
      }
    },
    {
      "apply": {
        "model": "my_mod:block/node_standard_energy_2"
      },
      "when": {
        "energy": "2"
      }
    },
    {
      "apply": {
        "model": "my_mod:block/node_standard_energy_3"
      },
      "when": {
        "energy": "3"
      }
    },
    {
      "apply": {
        "model": "my_mod:block/node_standard_energy_4"
      },
      "when": {
        "energy": "4"
      }
    },
    {
      "apply": {
        "model": "my_mod:block/node_standard_connected"
      },
      "when": {
        "connected": "true"
      }
    }
  ]
}