{:lint-as {cn.li.ac.util.init-guard/defonce-guard clojure.core/def
           cn.li.ac.util.init-guard/with-init-guard clojure.core/when
           cn.li.ac.ability.dsl/defcategory clojure.core/def}
 :hooks {:analyze-call {cn.li.ac.ability.dsl/defskill hooks.defskill/defskill}}
 :linters
 {:unresolved-symbol {:level :warning}
  :unused-private-var {:level :warning}
  ;; *framework* is initialized to nil and injected via alter-var-root at runtime.
  ;; clj-kondo cannot track the runtime injection, so suppress false-positive
  ;; nil-deref warnings on @*framework* across all namespaces.
  :deref {:level :off}}}
