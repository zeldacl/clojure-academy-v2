{:project-root "."

 :analysis {:summary? false
            ;; 【新增】核心止血：禁止扫描外部 JAR 包和依赖，只让 Claude 看你的源码
            :dependency-scheme "none"
            ;; 减少符号抓取的详细程度
            :level :project}

 ;; 【修改】暂时注释掉 classpath-cmd
 ;; 这是 Token 飞涨的根源。除非你需要 Claude 帮你解决复杂的库调用报错，
 ;; 否则不要让它去跑 Gradle 打印那一串几百个 JAR 包的路径。
 :project-specs []

 :source-paths ["api/src/main/clojure"
                "api/src/main/java"
                "mcmod/src/main/clojure"
                "mcmod/src/main/java"
                "ac/src/main/clojure"
                "ac/src/main/java"
                "forge-1.20.1/src/main/clojure"
                "forge-1.20.1/src/main/java"
                "fabric-1.20.1/src/main/clojure"
                "fabric-1.20.1/src/main/java"]

 ;; 顶层排除才会阻止 clojure-lsp 建索引；放在 :linters 下只影响/可能只影响 clj-kondo。
 :exclude-files ["build/.*"
                 ".*[/\\\\]build[/\\\\].*"
                 "bin/.*"
                 ".*[/\\\\]bin[/\\\\].*"
                 "out/.*"
                 "target/.*"
                 "classes/.*"
                 "\\.gradle/.*"
                 ".*[/\\\\]\\.gradle[/\\\\].*"
                 ".*[/\\\\]src[/\\\\]generated[/\\\\].*"
                 ".*[/\\\\]run[/\\\\].*"
                 ".*[/\\\\]run-data[/\\\\].*"
                 ".*[/\\\\]run-gametest[/\\\\].*"
                 "\\.lsp[/\\\\]\\.cache[/\\\\].*"
                 "\\.clj-kondo[/\\\\]\\.cache[/\\\\].*"
                 "hs_err_pid.*\\.log"
                 "replay_pid.*\\.log"
                 ".*\\.jfr"
                 ".*\\.log"
                 ".*\\.log\\.gz"
                 "build-.+\\.txt"
                 "compile-.+\\.txt"
                 ".*-verify.*\\.log"
                 ".*-bisect.*\\.txt"]

 :linters {:clj-kondo {:config {       ;; 告诉内核忽略对外部未定义符号的深度检索
                                :lint-as {core.async/go clojure.core/let}}}}}
