{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name} (Fabric)",
  "description": "A multi-loader Minecraft mod written in Clojure",
  "authors": ["${mod_authors}"],
  "contact": {
    "homepage": "https://example.com/",
    "sources": "https://github.com/example/${mod_id}"
  },
  "license": "MIT",
  "icon": "assets/${mod_id}/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      "cn.li.fabric1201.MyModFabric"
    ],
    "client": [
      "cn.li.fabric1201.MyModFabricClient"
    ],
    "fabric-datagen": [
      "cn.li.fabric1201.datagen.DataGeneratorSetup"
    ]
  },
  "mixins": [
    "${mod_id}.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.15.0",
    "minecraft": "~1.20.1",
    "java": ">=17",
    "fabric-api": "*"
  },
  "suggests": {}
}
