{
  "lsp": {
    "clojure": {
      "command": ["clojure-lsp", "listen"],
      "fileExtensions": ["clj", "cljs", "cljc", "edn"]
    }
  },
  "permissions": [
    {
      "type": "deny",
      "reasons": ["Build artifacts and compiled classes"],
      "globs": [
        "**/bin/**",
        "**/build/**",
        "**/.gradle/**",
        "**/out/**",
        "**/target/**",
        "**/src/generated/**",
        "**/run/**",
        "**/run-data/**",
        "**/run-gametest/**",
        "**/.lsp/**",
        "**/.clj-kondo/.cache/**",
        "**/*.log",
        "**/*.log.gz",
        "**/hs_err_pid*.log",
        "**/replay_pid*.log",
        "**/*.jfr"
      ]
    },
    {
      "type": "deny",
      "reasons": ["IDE and System noise"],
      "globs": [
        "**/.idea/**",
        "**/.settings/**",
        "**/*.iml",
        "**/.project",
        "**/.classpath"
      ]
    }
  ]
}
